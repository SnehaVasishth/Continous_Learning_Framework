# === App ===
APP_PORT=8000
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json   # or "text" for human-readable
APP_BASE_URL=http://localhost:8000   # public URL the app is reachable at
APP_CORS_ORIGINS=http://localhost:5173   # comma-separated list

# === Auth (bearer-token gate; SSO is phase-2) ===
APP_AUTH_ENABLED=false   # set true in production
APP_AUTH_TOKEN=          # 32+ char random string; required if APP_AUTH_ENABLED=true

# === Database ===
DATABASE_URL=            # blank → SQLite file at backend/data/db/app.db
                         # postgresql://user:pass@host:5432/dbname for production

# === Secrets (Fernet) ===
EMAIL_SECRET_KEY=        # 32-byte url-safe-base64 Fernet key; auto-generated locally if absent

# === Object storage ===
STORAGE_BACKEND=local    # local | s3 | azure_blob (s3/azure are phase-2 stubs)
STORAGE_LOCAL_UPLOADS=backend/data/uploads
STORAGE_LOCAL_OUTPUTS=backend/data/outputs

# === Translation provider ===
TRANSLATION_PROVIDER=llm     # llm | azure | deepl | google

# Azure AI Translator (used when TRANSLATION_PROVIDER=azure)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=global   # e.g. eastus, westeurope, or global
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# DeepL (used when TRANSLATION_PROVIDER=deepl)
DEEPL_API_KEY=
DEEPL_PLAN=free              # free | pro

# Google Cloud Translate v2 (used when TRANSLATION_PROVIDER=google)
GOOGLE_TRANSLATE_KEY=

# === Document text extraction (priority order: Lambda > Azure-direct > local) ===
# 1. AWS Lambda wrapping Azure Document Intelligence (preferred default for the demo).
#    Accepts {"pdf_url": "..."} and returns {"content": "...", "filePath": "<S3 url>"}.
LAMBDA_DOCEXTRACT_URL=https://5lmviqwda5jtgple2hnad7vibq0qqlnt.lambda-url.us-east-2.on.aws

# 2. Azure Document Intelligence direct (used when LAMBDA_DOCEXTRACT_URL not set, or as fallback).
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_KEY=

# === Optional: SharePoint Online via Microsoft Graph ===
# Used by Stage 2 to pull customer-specific documents during extraction.
# Stub returns ok with count=0 + a "not_configured" note when these are blank.
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=

# === LLM tracing (debug) ===
LLM_TRACE=0              # 1 to dump prompts/responses to backend/data/llm_trace

# === Postgres (docker-compose only) ===
POSTGRES_USER=zbrain
POSTGRES_PASSWORD=zbrain
POSTGRES_DB=zbrain
