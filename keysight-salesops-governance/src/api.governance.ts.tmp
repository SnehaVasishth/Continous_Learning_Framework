    root: {
      label: string;
      did: string;
      ring: string;
      capabilities: string[];
      delegation_depth: number;
      status: string;
    };
    agents: {
      label: string;
      did: string;
      ring: number;
      capabilities: string[];
      dropped_capabilities: string[];
      scope_narrowed: boolean;
      delegation_depth: number;
      parent_did: string;
      status: string;
      sponsor_role: string;
